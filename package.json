{
    "name": "vue-web-ui-template",
    "private": true,
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "preview": "vite preview",
        "lint": "eslint src",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "postinstall": "mkdir -p .ci && touch .ci/frontend .ci/dockerdeploy",
        "generate-types": "openapi-typescript openapi.yaml -o src/generated/types.ts"
    },
    "dependencies": {
        "@mdi/font": "^7.4.47",
        "pinia": "^2.1.7",
        "vue": "^3.4.0",
        "vue-router": "^4.3.0",
        "vuetify": "^3.12.8"
    },
    "devDependencies": {
        "@vitejs/plugin-vue": "^6.0.7",
        "eslint": "^8.56.0",
        "prettier": "^3.2.5",
        "vite": "^8.1.0",
        "openapi-typescript": "^7.13.0"
    },
    "allowScripts": {
        "vue-demi@0.14.10": true
    }
}
